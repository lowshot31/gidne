---
import '../styles/global.css';
import TickerStripClient from '../components/TickerStripClient';
import ThemeToggle from '../components/ThemeToggle';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Gidne v2 - Financial Dashboard" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
		<link rel="manifest" href="/manifest.json">
		<meta name="theme-color" content="#0a0a0a">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<div class="dashboard-container">
			<!-- Header / Nav -->
			<header class="app-header">
				<div class="logo">GIDNE</div>
				<nav class="tabs">
					<a href="/" class="active">Equities</a>
					<a href="/indices">Indices</a>
					<a href="/macro">Macro</a>
					<a href="/flows">Flows</a>
				</nav>
				<div style="display: flex; gap: 1rem; align-items: center;">
					<a href="/chart/SPY" class="search-bar">🔍 Search</a>
					<ThemeToggle client:load />
				</div>
			</header>

			<!-- Ticker Strip React Island -->
			<TickerStripClient client:load />

			<!-- Main Content -->
			<main class="dashboard-content">
				<slot />
			</main>
		</div>

		<style>
			.dashboard-container {
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			.app-header {
				display: flex;
				align-items: center;
				padding: var(--gap-sm) var(--gap-md);
				border-bottom: 1px solid var(--border-color);
				background: var(--bg-secondary);
			}
			.logo {
				font-family: var(--font-heading);
				font-size: 1.3rem;
				font-weight: 600;
				letter-spacing: 0.08em;
				color: var(--accent-primary);
				margin-right: var(--gap-lg);
			}
			.tabs {
				display: flex;
				gap: var(--gap-md);
				flex: 1;
			}
			.tabs a {
				color: var(--text-muted);
				text-decoration: none;
				font-size: 0.9rem;
				font-weight: 500;
				padding-bottom: 4px;
				transition: color var(--transition-fast);
			}
			.tabs a:hover {
				color: var(--text-secondary);
			}
			.tabs a.active {
				color: var(--text-primary);
				border-bottom: 2px solid var(--accent-primary);
			}
			.search-bar {
				color: var(--text-muted);
				font-size: 0.9rem;
				text-decoration: none;
				cursor: pointer;
				padding: 0.4rem 0.8rem;
				border: 1px solid var(--glass-border);
				border-radius: var(--radius-sm);
				transition: all 0.2s ease;
			}
			.search-bar:hover {
				border-color: var(--accent-primary);
				color: var(--text-primary);
			}
			.ticker-strip {
				display: flex;
				gap: var(--gap-md);
				padding: 8px var(--gap-md);
				font-family: var(--font-mono);
				font-size: 0.85rem;
				border-bottom: 1px solid var(--border-color);
				background: var(--bg-secondary);
			}
			.dashboard-content {
				flex: 1;
				padding: var(--gap-md);
			}
		</style>
	</body>
</html>
